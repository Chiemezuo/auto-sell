# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=auto_sell.settings.local

# Database (matches docker-compose defaults)
DATABASE_URL=postgres://autosell:autosell@localhost:5432/autosell

# Redis (matches docker-compose defaults)
REDIS_URL=redis://localhost:6379/0

# WhatsApp
WA_API_BASE=https://graph.facebook.com/v19.0

# DeepSeek
DEEPSEEK_API_KEY=sk-...

# Paystack
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...

# Cloudflare R2 (or AWS S3)
S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=auto-sell-media
S3_REGION=auto
# For AWS S3: https://<bucket>.s3.<region>.amazonaws.com
# For Cloudflare R2: your custom public domain or R2 public URL (e.g. https://pub-<hash>.r2.dev)
S3_CDN_BASE_URL=
